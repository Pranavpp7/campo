# Campo environment — copy to .env and fill in the keys.
#   cp .env.example .env
# .env is gitignored; never commit real keys.

# ── LLM providers (required) ─────────────────────────────────────────────────
# Groq — classifier, synthesis and agent models.  https://console.groq.com
GROQ_API_KEY=
# OpenRouter — used by llm/factory.py.  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Data & search APIs (required) ────────────────────────────────────────────
# football-data.org v4 — fixtures, scores, standings. Free tier is enough.
FOOTBALL_DATA_API_KEY=
# Tavily — web search used by the agents.  https://tavily.com
TAVILY_API_KEY=

# ── Infrastructure ───────────────────────────────────────────────────────────
# Defaults match docker-compose.yml — leave as-is for local development.
QDRANT_HOST=localhost
# 6335 matches docker-compose.yml (6333 is a common collision with other
# local Qdrant containers).
QDRANT_PORT=6335
REDIS_HOST=localhost
REDIS_PORT=6379
# Managed Redis (e.g. Upstash rediss://... URL) — overrides host/port when set.
# REDIS_URL=
# Production CORS: comma-separated frontend origins (defaults to localhost:3000).
# ALLOWED_ORIGINS=

# ── Pre-match briefs ─────────────────────────────────────────────────────────
# Competition to serve (football-data.org code): WC, PL, CL, ...
COMPETITION_CODE=WC
# Auto-generate briefs for today's matches on a 30-minute scan (backend must
# stay running). Off by default; briefs can always be generated on demand
# from the UI or POST /briefs/{match_id}/generate.
BRIEFS_AUTO_GENERATE=false
# Parallel research workers per brief. Default 2 — free-tier LLM quotas can't
# absorb a 4-way burst; raise it if you have paid-tier keys.
BRIEF_WORKER_CONCURRENCY=2
# Inside this many minutes before kickoff, a ready brief generated earlier is
# regenerated once, picking up confirmed lineups and late team news.
BRIEF_REFRESH_WINDOW_MINUTES=90

# ── Optional: tracing & telemetry ────────────────────────────────────────────
# LangSmith tracing (read by the langchain library when enabled).
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=campo
LANGSMITH_API_KEY=
# Opt out of DeepEval telemetry during eval runs (YES to opt out).
DEEPEVAL_TELEMETRY_OPT_OUT=YES
