# Campo environment — copy to .env and fill in the keys.
#   cp .env.example .env
# .env is gitignored; never commit real keys.

# ── LLM providers (required) ─────────────────────────────────────────────────
# Groq — classifier, synthesis and agent models.  https://console.groq.com
GROQ_API_KEY=
# OpenRouter — used by llm/factory.py.  https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Data & search APIs (required) ────────────────────────────────────────────
# football-data.org v4 — fixtures, scores, standings. Free tier is enough.
FOOTBALL_DATA_API_KEY=
# Tavily — web search used by the agents.  https://tavily.com
TAVILY_API_KEY=

# ── Infrastructure ───────────────────────────────────────────────────────────
# Defaults match docker-compose.yml — leave as-is for local development.
QDRANT_HOST=localhost
QDRANT_PORT=6333
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Optional: tracing & telemetry ────────────────────────────────────────────
# LangSmith tracing (read by the langchain library when enabled).
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=campo
LANGSMITH_API_KEY=
# Opt out of DeepEval telemetry during eval runs (YES to opt out).
DEEPEVAL_TELEMETRY_OPT_OUT=YES
